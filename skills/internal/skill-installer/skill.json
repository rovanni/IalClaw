{
  "name": "skill-installer",
  "kind": "internal",
  "trusted": true,
  "version": "1.0.0",
  "entry": "SKILL.md",
  "marketplace": "https://skills.sh/",
  "invocation": {
    "slashCommands": [
      "/install-skill <tema>",
      "/find-skill <tema>",
      "/skill-install <nome-exato>"
    ],
    "freeText": [
      "skill",
      "skills",
      "instalar skill",
      "baixar skill",
      "skills disponíveis",
      "melhor skill para",
      "procure uma skill",
      "procura uma skill",
      "buscar skill",
      "busque uma skill",
      "encontre uma skill",
      "encontrar skill",
      "pesquisar skill",
      "pesquise uma skill",
      "tem uma skill",
      "existe uma skill",
      "há uma skill",
      "usar uma skill",
      "skill para isso",
      "skill para fazer",
      "skill que faz",
      "instalar habilidade",
      "nova skill",
      "adicionar skill"
    ]
  },
  "requiredTools": [
    "fetch_url",
    "write_skill_file",
    "delete_skill_public",
    "read_audit_log",
    "run_skill_auditor",
    "reload_skills",
    "web_search",
    "read_local_file",
    "list_local_dir"
  ],
  "pipeline": [
    "search",
    "present",
    "confirm",
    "download",
    "audit",
    "report"
  ],
  "security": {
    "alwaysAudit": true,
    "auditSkill": "skill-auditor",
    "blockOnDecisions": ["blocked", "quarantined"],
    "rollbackOnBlock": true
  }
}
